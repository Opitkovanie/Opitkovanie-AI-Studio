{
  "name": "opitkovanie-ai-studio",
  "private": true,
  "version": "6.0.4",
  "description": "Opitkovanie AI Studio – dubbing, shorty, napisy, muzyka, obraz i wideo lokalnie.",
  "author": "Opitkovanie",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Opitkovanie/Opitkovanie-AI-Studio.git"
  },
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "desktop": "npm run dev",
    "build": "tsc -b && vite build",
    "dist": "npm run build && electron-builder",
    "release": "npm run build && electron-builder --mac --arm64 --publish never",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.opitkovanie.dubcutstudio",
    "productName": "Opitkovanie AI Studio",
    "asar": false,
    "afterPack": "build/afterPack.cjs",
    "artifactName": "Opitkovanie-AI-Studio-${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Opitkovanie",
        "repo": "Opitkovanie-AI-Studio",
        "releaseType": "release"
      }
    ],
    "files": [
      "dist/**",
      "electron/**",
      "package.json",
      "!**/._*",
      "!**/.DS_Store"
    ],
    "extraResources": [
      {
        "from": "vendor",
        "to": "vendor",
        "filter": [
          "**/*",
          "!**/.venv/**",
          "!**/__pycache__/**",
          "!**/._*",
          "!**/.DS_Store",
          "!**/workspace/sessions/**",
          "!**/workspace/downloads/**",
          "!**/workspace/sessions",
          "!**/workspace/downloads",
          "!**/workspace/favorites",
          "!**/workspace/favorites/**",
          "!**/workspace/runtime/**"
        ]
      },
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/._*",
          "!**/.DS_Store"
        ]
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "target": ["dmg", "zip"],
      "category": "public.app-category.video"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "AudioVideo"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
